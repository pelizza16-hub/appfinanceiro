# Supabase - obtenha em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
# Estas são as únicas variáveis necessárias para rodar o projeto.
# Copie este arquivo para .env.local e preencha com os valores reais.
#
# SEGURANÇA:
# - Use apenas a "Publishable key" (anon key) — ela é projetada para ser pública
# - NUNCA coloque a "Secret key" (service_role) aqui ou em qualquer arquivo
# - O arquivo .env.local está no .gitignore e nunca será enviado ao repositório

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
